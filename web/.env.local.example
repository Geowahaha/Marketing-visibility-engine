# Copy to a local .env (never commit real values) OR set these in
# Cloudflare Pages → Settings → Variables and Secrets.

# --- LLM for scan / improve / competitor (need at least one) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Optional: pick the model (default claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6
# Optional backup providers — automatic failover order is Anthropic → Groq → Kimi.
# Both are OpenAI-compatible. (They do NOT power the live citation probe — that
# needs web grounding via Gemini/Perplexity below.)
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile
# KIMI_API_KEY=sk-...
# KIMI_MODEL=kimi-k2-0905-preview
# KIMI_BASE_URL=https://api.moonshot.ai/v1
# Optional: override the failover order, e.g. "groq,anthropic,kimi"
# LLM_PROVIDER_ORDER=anthropic,groq,kimi
# Optional: scans allowed per IP per hour (default 5; requires RATE_LIMIT_KV)
RATE_LIMIT_MAX=5
# Optional: Google PageSpeed Insights key for real Core Web Vitals (higher quota)
GOOGLE_PSI_KEY=your_google_psi_api_key

# --- Before/After analytics (required for /analytics.html) ---
CF_API_TOKEN=cf_token_with_Analytics_Read
CF_ZONE_TAG=your_cloudflare_zone_id

# --- Monetization: checkout + paywall (Improve Engine, export, deploy) ---
# Secret that unlocks paid artifacts (also minted as the aimark_paid_export cookie).
PAID_EXPORT_SECRET=choose_a_long_random_secret
# Stripe (PromptPay/cards friendly). Enables real /api/checkout sessions.
STRIPE_SECRET_KEY=sk_live_or_test_xxx
# Stripe webhook signing secret for /api/checkout/webhook (Developers → Webhooks).
# Subscribe to: checkout.session.completed, checkout.session.async_payment_succeeded,
# checkout.session.async_payment_failed. PromptPay QR can settle asynchronously.
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Optional: checkout currency (default thb) and canonical site origin.
CHECKOUT_CURRENCY=thb
SITE_ORIGIN=https://aimark.pages.dev

# --- OAuth login / GitHub repo connect ---
# Google OAuth web app redirect URI:
#   https://aimark.pages.dev/api/auth/callback/google
# GitHub OAuth App callback URL:
#   https://aimark.pages.dev/api/auth/callback/github
GOOGLE_CLIENT_ID=google_oauth_client_id
GOOGLE_CLIENT_SECRET=google_oauth_client_secret
GITHUB_CLIENT_ID=github_oauth_client_id
GITHUB_CLIENT_SECRET=github_oauth_client_secret

# --- Live AI-citation probe (/api/citation-probe) — at least one to run live ---
GEMINI_API_KEY=your_gemini_api_key
PERPLEXITY_API_KEY=your_perplexity_api_key
# Optional: Perplexity model (default sonar)
PERPLEXITY_MODEL=sonar

# --- KV namespaces to bind in Cloudflare Pages → Settings → Functions ---
# RATE_LIMIT_KV   – per-IP scan rate limiting (existing)
# ENTITLEMENTS_KV – who paid for what, written by the Stripe webhook
# PROOF_KV        – per-account scan baselines for before/after proof
#   Create:  npx wrangler kv namespace create ENTITLEMENTS_KV
#            npx wrangler kv namespace create PROOF_KV
#   then bind each id under the matching binding name.
